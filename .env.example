# Copy this file to `.env` (gitignored) or to ~/.trading-agent-skills/.env, then fill in keys.
#
# Used by `trading-agent-skills-news` (skill 4: session-news-brief). Any missing key is
# non-fatal — the corresponding provider is skipped and a MISSING_NEWS_API_KEY
# flag surfaces in the brief output. Real shell env vars always win over .env,
# so you can also set these via PowerShell ($env:FINNHUB_API_KEY = "...") or
# bash (export FINNHUB_API_KEY=...).
#
# Search order:
#   1. ~/.trading-agent-skills/.env  (preferred — survives across project locations)
#   2. ./.env              (repo-local override for development)
#   3. --env-file <path>   (CLI flag override)

FINNHUB_API_KEY=
MARKETAUX_API_KEY=
FOREXNEWS_API_KEY=
